# Environment Mode
# NODE_ENV and APP_ENV should be one of: development, staging, production
NODE_ENV=development
APP_ENV=development
APP_NAME=CloudTune API
APP_VERSION=0.1.0
HOST=0.0.0.0
PORT=4000
APP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Auth
JWT_SECRET=replace-with-a-strong-secret-min-16
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=replace-with-a-different-strong-secret-min-16
REFRESH_TOKEN_EXPIRES_IN=30d
AUTH_PASSWORD_HASH_ROUNDS=12
AUTH_SOCIAL_GOOGLE_ENABLED=false
AUTH_SOCIAL_GOOGLE_CLIENT_ID=
AUTH_SOCIAL_APPLE_ENABLED=false
AUTH_SOCIAL_APPLE_SERVICE_ID=

# Database
DATABASE_URL=postgres://cloudtune:cloudtune@localhost:5432/cloudtune
DB_POOL_MIN=1
DB_POOL_MAX=10
DB_STATEMENT_TIMEOUT_MS=12000

# Storage
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_USE_SSL=false
STORAGE_ACCESS_KEY=cloudtune
STORAGE_SECRET_KEY=replace-with-a-secret
STORAGE_BUCKET=cloudtune-media
STORAGE_REGION=us-east-1
STORAGE_SIGNED_URL_TTL_SECONDS=900

# Audio
AUDIO_MAX_UPLOAD_MB=250
AUDIO_ALLOWED_MIME_TYPES=audio/mpeg,audio/flac,audio/wav,audio/x-wav,audio/aac,audio/mp4
AUDIO_WAVEFORM_ENABLED=true
AUDIO_OFFLINE_TTL_HOURS=720
PLAYBACK_SIGNED_URL_TTL_SECONDS=900

# Notifications
NOTIFICATIONS_PUSH_ENABLED=true
NOTIFICATIONS_EMAIL_ENABLED=true
NOTIFICATIONS_PROVIDER=none
NOTIFICATIONS_API_KEY=
NOTIFICATIONS_FROM_EMAIL=noreply@cloudtune.local

# Ads
ADS_ENABLED=false
ADS_PROVIDER=none
ADS_APP_ID=
ADS_BANNER_UNIT_ID=
ADS_INTERSTITIAL_UNIT_ID=
ADS_REWARDED_UNIT_ID=

# Subscriptions
SUBSCRIPTIONS_ENABLED=true
SUBSCRIPTIONS_PROVIDER=none
SUBSCRIPTIONS_WEBHOOK_SECRET=
SUBSCRIPTIONS_DEFAULT_PLAN_CODE=FREE
SUBSCRIPTIONS_TRIAL_DAYS=14

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_PROVIDER=none
ANALYTICS_WRITE_KEY=
ANALYTICS_SAMPLE_RATE=1